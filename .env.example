# ── Required ──────────────────────────────────────────────────
# Your Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# ── Group Forwarding (optional but recommended) ───────────────
# Telegram Group Chat ID where ALL inbound SMS will be forwarded.
# Example: GROUP_CHAT_ID=-1001234567890
#
# How to get your group chat ID:
#   1. Add @userinfobot to your group
#   2. It will reply with the group's Chat ID (starts with -100)
#
# This acts as a global default for every user logged into the bot.
# Individual users can still override it with their own group
# via the 📢 Set Group Forwarding button inside the bot.
GROUP_CHAT_ID=-100xxxxxxxxxx
